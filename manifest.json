{
  "manifest_version": 3,
  "name": "Claude Prompts Dock",
  "version": "1.0.0",
  "description": "A floating sidebar companion to search, bookmark, and export your chat prompts effortlessly.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "dock.css"
      ]
    }
  ]
}